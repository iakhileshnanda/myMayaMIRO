# ================================
# Maya MIRO — NVIDIA NIM Config
# ================================

# LLM — NVIDIA NIM (replaces Ollama completely)
LLM_API_KEY=your_nvidia_nim_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL_NAME=qwen/qwen3.5-397b-a17b

# Neo4j (runs locally via Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# Embeddings — NVIDIA NIM free endpoint (replaces nomic-embed-text)
EMBEDDING_MODEL=nvidia/nv-embed-v1
EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDING_API_KEY=your_nvidia_nim_api_key_here